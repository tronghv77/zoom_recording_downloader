{
  "name": "zoom-recording-downloader",
  "version": "0.3.0",
  "description": "Hybrid desktop app for managing and downloading Zoom Cloud recordings across multiple accounts and devices",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .\"",
    "start": "tsc -p tsconfig.electron.json && vite build && cross-env ELECTRON_RUN_AS_NODE= electron .",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:server": "tsc -p tsconfig.server.json",
    "start:server": "tsc -p tsconfig.server.json && vite build && node dist/server/server/index.js",
    "dev:server": "tsc -p tsconfig.server.json && concurrently \"vite\" \"node dist/server/server/index.js\"",
    "dist": "tsc -p tsconfig.electron.json && vite build && electron-builder --win",
    "preview": "vite preview",
    "lint": "eslint src/ electron/ server/",
    "typecheck": "tsc --noEmit",
    "build:agent": "node scripts/build-agent.js",
    "build:agent:exe": "node scripts/build-agent.js --exe"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.6",
    "electron-store": "^8.2.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "session-file-store": "^1.5.0",
    "sql.js": "^1.10.0",
    "ws": "^8.19.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@yao-pkg/pkg": "^6.14.1",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^24.13.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.5.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.zoomrecording.downloader",
    "productName": "Zoom Recording Downloader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/electron/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "sign": false,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerSidebar": null
    },
    "portable": {
      "artifactName": "ZoomRecordingDownloader-portable.exe"
    }
  }
}
