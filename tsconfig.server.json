{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "baseUrl": "."
  },
  "include": ["server/**/*", "src/shared/**/*", "src/services/**/*", "src/database/**/*"],
  "exclude": ["node_modules"]
}
